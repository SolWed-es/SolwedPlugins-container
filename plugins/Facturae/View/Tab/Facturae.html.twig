                    <input type="text" name="prunidad" value="{{ facturae.prunidad | raw }}"
                           placeholder="{{ i18n.trans('optional') }}" class="form-control"/>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-12">
                <h3 class="h5 mt-3 mb-0">Órgano proponente</h3>
                <p class="text-muted mb-1">
                    Puedes dejar en blanco los campos nombre, dirección, código postal,
                    ciudad y provincia para usar los del cliente.
                </p>
            </div>
        </div>
        <div class="form-row">
            <div class="col-sm-2">
                <div class="form-group">
                    {{ i18n.trans('code') }}
                    <input type="text" name="codorganop" value="{{ facturae.codorganop | raw }}"
