<view>
    <columns>
        <group name="main" numcolumns="12">
            <column name="code" display="none" order="100">
                <widget type="text" fieldname="id"/>
            </column>
            <column name="status" order="110">
                <widget type="select" fieldname="idestado" icon="fa-solid fa-tags"
                        onclick="AdminCRM?activetab=EditCrmOportunidadEstado" required="true">
                    <values source="CrmOportunidadEstado" fieldcode="id"/>
                </widget>
            </column>
            <column name="contact" titleurl="ListContacto" order="120">
                <widget type="autocomplete" fieldname="idcontacto" onclick="EditContacto" required="true">
                    <values source="Contacto" fieldcode="idcontacto" fieldtitle="descripcion"/>
                </widget>
            </column>
            <column name="interest" titleurl="AdminCRM?activetab=ListCrmInteres" order="130">
                <widget type="select" fieldname="idinteres" icon="fa-solid fa-heart" onclick="EditCrmInteres">
                    <values source="crm_intereses" fieldcode="id" fieldtitle="nombre"/>
                </widget>
            </column>
            <column name="agent" titleurl="ListAgente" order="140">
                <widget type="select" fieldname="codagente" icon="fa-solid fa-user-tie" onclick="EditAgente">
                    <values source="agentes" fieldcode="codagente" fieldtitle="nombre"/>
                </widget>
            </column>
            <column name="assigned" order="150">
                <widget type="select" fieldname="asignado" icon="fa-solid fa-user">
                    <values source="User" fieldcode="nick"/>
                </widget>
            </column>
            <column name="description" numcolumns="12" order="160">
                <widget type="textarea" fieldname="descripcion" required="true"/>
            </column>
            <column name="observations" display="none" numcolumns="12" order="160">
                <widget type="textarea" fieldname="observaciones"/>
            </column>
        </group>
        <group name="more" numcolumns="12">
            <column name="approximate-price" order="100">
                <widget type="money" fieldname="precio_aprox"/>
            </column>
            <column name="user" order="110">
                <widget type="select" fieldname="nick" readonly="true">
                    <values source="User" fieldcode="nick"/>
                </widget>
            </column>
            <column name="date" order="120">
                <widget type="date" fieldname="fecha" readonly="true"/>
            </column>
            <column name="hour" order="130">
                <widget type="string" fieldname="hora" readonly="true"/>
            </column>
            <column name="last-update" order="140">
                <widget type="datetime" fieldname="fechamod" readonly="true"/>
            </column>
            <column name="deadline" order="150">
                <widget type="date" fieldname="fecha_cierre" readonly="true"/>
            </column>
        </group>
    </columns>
</view>