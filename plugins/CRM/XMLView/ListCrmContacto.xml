<view>
    <columns>
        <column name="code" display="none" order="100">
            <widget type="text" fieldname="idcontacto" onclick="EditContacto"/>
        </column>
        <column name="description" display="none" order="110">
            <widget type="textarea" fieldname="descripcion"/>
        </column>
        <column name="name" order="120">
            <widget type="text" fieldname="nombre"/>
        </column>
        <column name="surname" order="130">
            <widget type="text" fieldname="apellidos"/>
        </column>
        <column name="company" display="none" order="140">
            <widget type="text" fieldname="empresa"/>
        </column>
        <column name="position" display="none" order="150">
            <widget type="text" fieldname="cargo"/>
        </column>
        <column name="fiscal-number" display="none" order="160">
            <widget type="text" fieldname="cifnif"/>
        </column>
        <column name="email" order="170">
            <widget type="text" fieldname="email"/>
        </column>
        <column name="phone" order="180">
            <widget type="text" fieldname="telefono1"/>
        </column>
        <column name="phone2" order="190">
            <widget type="text" fieldname="telefono2"/>
        </column>
        <column name="address" display="none" order="200">
            <widget type="text" fieldname="direccion"/>
        </column>
        <column name="city" order="210">
            <widget type="text" fieldname="ciudad"/>
        </column>
        <column name="province" order="220">
            <widget type="text" fieldname="provincia"/>
        </column>
        <column name="country" order="230">
            <widget type="select" fieldname="codpais">
                <values source="paises" fieldcode="codpais" fieldtitle="nombre"/>
            </widget>
        </column>
        <column name="agent" display="none" order="240">
            <widget type="select" fieldname="codagente">
                <values source="agentes" fieldcode="codagente" fieldtitle="nombre"/>
            </widget>
        </column>
        <column name="source" display="none" order="250">
            <widget type="select" fieldname="idfuente">
                <values source="crm_fuentes2" fieldcode="id" fieldtitle="nombre"/>
            </widget>
        </column>
        <column name="observations" display="none" order="260">
            <widget type="text" fieldname="observaciones"/>
        </column>
        <column name="creation-date" display="none" order="300">
            <widget type="date" fieldname="fechaalta"/>
        </column>
    </columns>
    <rows>
        <row type="status">
            <option color="success" fieldname="codcliente" title="customer">notnull:</option>
            <option color="danger" fieldname="email" title="missing-email"></option>
            <option color="danger" fieldname="email" title="missing-email">null:</option>
            <option color="warning" fieldname="telefono1" title="missing-phone"></option>
            <option color="warning" fieldname="telefono1" title="missing-phone">null:</option>
            <option color="warning" fieldname="verificado" title="not-verified">0</option>
        </row>
    </rows>
</view>