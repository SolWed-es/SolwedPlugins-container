<?xml version="1.0" encoding="UTF-8"?>
<view>
    <columns>
        <column name="id" display="none" order="100">
            <widget type="text" fieldname="id"/>
        </column>
        <column name="name" order="110">
            <widget type="text" fieldname="name"/>
        </column>
        <column name="subject" order="120">
            <widget type="text" fieldname="subject"/>
        </column>
        <column name="content" display="none" order="130">
            <widget type="textarea" fieldname="content"/>
        </column>
        <column name="emails" display="right" order="140">
            <widget type="number" fieldname="num_emails" decimal="0"/>
        </column>
        <column name="sent" display="left" order="150">
            <widget type="number" fieldname="num_sent" decimal="0"/>
        </column>
        <column name="send-start-hour" display="none" order="155">
            <widget type="number" fieldname="send_start_hour" decimal="0"/>
        </column>
        <column name="send-end-hour" display="none" order="156">
            <widget type="number" fieldname="send_end_hour" decimal="0"/>
        </column>
        <column name="status" order="170">
            <widget type="select" fieldname="status" translate="true">
                <values title="sketch">0</values>
                <values title="send">1</values>
                <values title="sent">2</values>
            </widget>
        </column>
        <column name="creation-date" display="right" order="180">
            <widget type="datetime" fieldname="creation_date" required="true"/>
        </column>
        <column name="last-update" display="none" order="190">
            <widget type="datetime" fieldname="last_update"/>
        </column>
    </columns>
    <rows>
        <row type="status">
            <option color="warning" fieldname="status" title="send">1</option>
            <option color="success" fieldname="status" title="sent">2</option>
        </row>
    </rows>
</view>