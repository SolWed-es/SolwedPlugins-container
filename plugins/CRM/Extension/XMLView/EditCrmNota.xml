<?xml version="1.0" encoding="UTF-8"?>

<view>
    <columns>
        <group name="calendar">
            <column name="start-date" numcolumns="2" order="50">
                <widget type="date" fieldname="startdate"/>
            </column>
            <column name="start-time" numcolumns="2" order="60">
                <widget type="time" fieldname="starttime"/>
            </column>
            <column name="end-date" numcolumns="2" order="70">
                <widget type="date" fieldname="enddate"/>
            </column>
            <column name="end-time" numcolumns="2" order="80">
                <widget type="time" fieldname="endtime"/>
            </column>
        </group>
    </columns>
</view>
