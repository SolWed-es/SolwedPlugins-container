<?xml version="1.0" encoding="UTF-8"?>
<!--
    Document   : rrhh_employeesshifts.xml
    Author     : José Ferrán
    Description: Table structure for employee shift assignments

    This file is part of HHRRSolwedTurnosSemana plugin for FacturaScripts.
    Developed by José Ferrán based on the excellent work of the Human Resources
    plugin created by Carlos García Gómez and Jose Antonio Cuello Principal.
-->
<table>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idemployee</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>idshift</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>assignment_date</name>
        <type>date</type>
        <null>NO</null>
        <default>CURRENT_DATE</default>
    </column>
    <column>
        <name>start_date</name>
        <type>date</type>
    </column>
    <column>
        <name>end_date</name>
        <type>date</type>
    </column>
    <column>
        <name>notes</name>
        <type>text</type>
    </column>
    <column>
        <name>active</name>
        <type>boolean</type>
        <null>NO</null>
        <default>TRUE</default>
    </column>
    <column>
        <name>autoassignable</name>
        <type>boolean</type>
        <null>NO</null>
        <default>TRUE</default>
    </column>
    <column>
        <name>creation_date</name>
        <type>timestamp</type>
    </column>
    <column>
        <name>last_nick</name>
        <type>character varying(50)</type>
    </column>
    <column>
        <name>last_update</name>
        <type>timestamp</type>
    </column>
    <column>
        <name>nick</name>
        <type>character varying(50)</type>
    </column>
     <column>
            <name>isdefault</name>
            <type>boolean</type>
            <null>NO</null>
            <default>FALSE</default>
        </column>
    <constraint>
        <name>rrhh_employeesshifts_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>rrhh_employeesshifts_employee_fkey</name>
        <type>FOREIGN KEY (idemployee) REFERENCES rrhh_employees (id) ON DELETE CASCADE</type>
    </constraint>
    <constraint>
        <name>rrhh_employeesshifts_shift_fkey</name>
        <type>FOREIGN KEY (idshift) REFERENCES rrhh_shifts (id) ON DELETE CASCADE</type>
    </constraint>
    <constraint>
        <name>rrhh_employeesshifts_date_check</name>
        <type>CHECK (end_date IS NULL OR start_date IS NULL OR end_date >= start_date)</type>
    </constraint>
    <index>
        <name>idx_rrhh_employeesshifts_employee</name>
        <column>idemployee</column>
    </index>
    <index>
        <name>idx_rrhh_employeesshifts_shift</name>
        <column>idshift</column>
    </index>
    <index>
        <name>idx_rrhh_employeesshifts_active</name>
        <column>active</column>
    </index>
    <index>
        <name>idx_rrhh_employeesshifts_dates</name>
        <column>start_date</column>
        <column>end_date</column>
    </index>
    <index>
        <name>idx_rrhh_employeesshifts_employee_active</name>
        <column>idemployee</column>
        <column>active</column>
    </index>
</table>