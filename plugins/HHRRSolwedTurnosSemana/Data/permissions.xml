<?xml version="1.0" encoding="UTF-8"?>
<!--
    Document   : permissions.xml
    Author     : Carlos Garcia Gomez
    Description: Permissions configuration for HHRRSolwedTurnosSemana plugin
-->
<permissions>
    <!-- Employee permissions -->
    <role name="employee">
        <controller name="MyShifts" access="read" />
    </role>
    
    <!-- HR Manager permissions -->
    <role name="hr_manager">
        <controller name="MyShifts" access="read" />
        <controller name="ListShift" access="read,write,delete" />
        <controller name="EditShift" access="read,write,delete" />
        <controller name="ListEmployeeShift" access="read,write,delete" />
        <controller name="EditEmployeeShift" access="read,write,delete" />
        <controller name="AssignShift" access="read,write" />
        <controller name="ListShiftRequest" access="read,write" />
        <controller name="EditShiftRequest" access="read,write" />
    </role>
    
    <!-- Admin permissions -->
    <role name="admin">
        <controller name="MyShifts" access="read" />
        <controller name="ListShift" access="read,write,delete" />
        <controller name="EditShift" access="read,write,delete" />
        <controller name="ListEmployeeShift" access="read,write,delete" />
        <controller name="EditEmployeeShift" access="read,write,delete" />
        <controller name="AssignShift" access="read,write,delete" />
        <controller name="ListShiftRequest" access="read,write,delete" />
        <controller name="EditShiftRequest" access="read,write,delete" />
    </role>
</permissions>