<table>
    <column>
        <name>idruta</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>nombre</name>
        <type>character varying(120)</type>
        <null>NO</null>
    </column>
    <column>
        <name>fecha_inicio</name>
        <type>date</type>
        <null>NO</null>
    </column>
    <column>
        <name>fecha_fin</name>
        <type>date</type>
    </column>
    <column>
        <name>optimizada</name>
        <type>boolean</type>
        <null>NO</null>
        <default>false</default>
    </column>
    <column>
        <name>datos_extra</name>
        <type>text</type>
    </column>
    <column>
        <name>created_at</name>
        <type>timestamp</type>
        <null>NO</null>
    </column>
    <column>
        <name>updated_at</name>
        <type>timestamp</type>
        <null>NO</null>
    </column>

    <constraint>
        <name>rutas_pkey</name>
        <type>PRIMARY KEY (idruta)</type>
    </constraint>
</table>
