<table>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>location</name>
        <type>character varying(100)</type>
        <null>NO</null>
    </column>
    <column>
        <name>shift_number</name>
        <type>integer</type>
        <null>NO</null>
        <default>1</default>
    </column>
    <column>
        <name>entry_time</name>
        <type>time</type>
        <null>NO</null>
        <default>'08:00:00'</default>
    </column>
    <column>
        <name>exit_time</name>
        <type>time</type>
        <null>NO</null>
        <default>'16:00:00'</default>
    </column>
    <column>
        <name>autoassignable</name>
        <type>boolean</type>
        <null>NO</null>
        <default>false</default>
    </column>
    <column>
        <name>notes</name>
        <type>text</type>
    </column>
    <column>
        <name>creation_date</name>
        <type>timestamp</type>
    </column>
    <column>
        <name>last_nick</name>
        <type>character varying(50)</type>
    </column>
    <column>
        <name>last_update</name>
        <type>timestamp</type>
    </column>
    <column>
        <name>nick</name>
        <type>character varying(50)</type>
    </column>
    <constraint>
        <name>rrhh_shifts_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>rrhh_shifts_unique</name>
        <type>UNIQUE (location, shift_number)</type>
    </constraint>
</table>
