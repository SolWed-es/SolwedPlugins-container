<view>
    <columns>
        <group name="localizacion" numcolumns="12" title="Localización" icon="fas fa-location">
            <column name="localizacion" numcolumns="8" order="110" >
                <widget type="text" fieldname="localizacion" />
            </column>
        </group>
        <group name="data" numcolumns="12">
            <column name="turno" numcolumns="6" order="145">
                <widget type="select" fieldname="idturno" required="false">
                    <values source="rrhh_shifts" fieldcode="id" fieldtitle="location"></values>
                </widget>
            </column>
            <column name="project" numcolumns="6" order="146">
                <widget type="select" fieldname="idproyecto" required="false">
                    <values source="proyectos" fieldcode="idproyecto" fieldtitle="nombre"></values>
                </widget>
            </column>
        </group>
    </columns>
</view>
