    <columns>
        <column name="localizacion" order="180" >
            <widget type="text" fieldname="localizacion" />
        </column>
        <column name="idturno" order="299">
            <widget type="select" fieldname="idturno" readonly="true">
                <values source="rrhh_shifts" fieldcode="id" fieldtitle="location"></values>
            </widget>
        </column>
    </columns>
</view>
