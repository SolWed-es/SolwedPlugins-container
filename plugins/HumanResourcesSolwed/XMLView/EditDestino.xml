<view>
    <columns>
        <group name="data" numcolumns="12" title="data">
            <column name="code" order="0" display="none">
                <widget type="text" fieldname="iddestino" readonly="true" />
            </column>
            <column name="name" order="100" numcolumns="8" title="Nombre">
                <widget type="text" fieldname="nombre" required="true" maxlength="120" />
            </column>
            <column name="reference" order="110" numcolumns="4" title="Referencia">
                <widget type="checkbox" fieldname="referencia" />
            </column>
            <column name="address" order="120" numcolumns="12" title="Dirección">
                <widget type="text" fieldname="direccion" maxlength="255" />
            </column>
            <column name="city" order="130" numcolumns="8" title="Ciudad">
                <widget type="text" fieldname="ciudad" maxlength="60" />
            </column>
            <column name="postal-code" order="140" numcolumns="4" title="Código Postal">
                <widget type="text" fieldname="cp" maxlength="10" />
            </column>
            <column name="start-date" order="150" numcolumns="6" title="Fecha Inicio">
                <widget type="date" fieldname="fecha_inicio" required="true" />
            </column>
            <column name="end-date" order="160" numcolumns="6" title="Fecha Fin">
                <widget type="date" fieldname="fecha_fin" />
            </column>
            <column name="duration" order="170" numcolumns="4" title="Duración (min)">
                <widget type="number" fieldname="duracion_min" min="1" max="1440" />
            </column>
            <column name="active" order="180" numcolumns="4" title="Activo">
                <widget type="checkbox" fieldname="activo" />
            </column>
            <column name="entry-time" order="190" numcolumns="6" title="Hora Entrada">
                <widget type="time" fieldname="hora_entrada" step="60" />
            </column>
            <column name="exit-time" order="200" numcolumns="6" title="Hora Salida">
                <widget type="time" fieldname="hora_salida" step="60" />
            </column>
        </group>
        <group name="coordinates" numcolumns="12" title="Coordenadas">
            <column name="lat" order="300" numcolumns="6" title="Latitud">
                <widget type="number" fieldname="lat" readonly="true" step="0.00001" />
            </column>
            <column name="lon" order="310" numcolumns="6" title="Longitud">
                <widget type="number" fieldname="lon" readonly="true" step="0.00001" />
            </column>
        </group>
    </columns>
</view>
