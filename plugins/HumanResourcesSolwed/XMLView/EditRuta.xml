<view>
    <columns>
        <group name="data" numcolumns="12" title="data">
            <column name="code" order="0" display="none">
                <widget type="text" fieldname="idruta" readonly="true" />
            </column>
            <column name="name" order="100" numcolumns="12" title="Nombre">
                <widget type="text" fieldname="nombre" required="true" maxlength="100" />
            </column>
            <column name="start-date" order="110" numcolumns="6" title="Fecha Inicio">
                <widget type="date" fieldname="fecha_inicio" required="true" />
            </column>
            <column name="end-date" order="120" numcolumns="6" title="Fecha Fin">
                <widget type="date" fieldname="fecha_fin" />
            </column>
            <column name="optimized" order="130" numcolumns="6" title="Optimizada">
                <widget type="checkbox" fieldname="optimizada" />
            </column>
            <column name="extra-data" order="140" numcolumns="12" title="Datos Extra">
                <widget type="textarea" fieldname="datos_extra" maxlength="0" />
            </column>
            <column name="created" order="150" numcolumns="6" title="Creado">
                <widget type="datetime" fieldname="created_at" readonly="true" />
            </column>
            <column name="updated" order="160" numcolumns="6" title="Actualizado">
                <widget type="datetime" fieldname="updated_at" readonly="true" />
            </column>
        </group>
    </columns>
</view>
