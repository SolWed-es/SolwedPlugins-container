<view>
    <columns>
        <column name="shift" order="100">
            <widget type="select" fieldname="idshift">
                <values source="rrhh_shifts" fieldcode="id" fieldtitle="location" />
            </widget>
        </column>
        <column name="day-of-week" order="110">
            <widget type="select" fieldname="dayofweek" required="true" translate="true">
                <values title="monday">1</values>
                <values title="tuesday">2</values>
                <values title="wednesday">3</values>
                <values title="thursday">4</values>
                <values title="friday">5</values>
                <values title="saturday">6</values>
                <values title="sunday">7</values>
            </widget>
        </column>
        <column name="morning-entry" order="120">
            <widget type="time" fieldname="morning_entry" />
        </column>
        <column name="morning-exit" order="130">
            <widget type="time" fieldname="morning_exit" />
        </column>
        <column name="afternoon-entry" order="140">
            <widget type="time" fieldname="afternoon_entry" />
        </column>
        <column name="afternoon-exit" order="150">
            <widget type="time" fieldname="afternoon_exit" />
        </column>
    </columns>
</view>
