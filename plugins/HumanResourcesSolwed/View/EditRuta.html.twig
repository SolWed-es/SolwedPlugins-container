{% extends "Master/EditController.html.twig" %}

{% block body %}
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <form id="form{{ model.modelClassName }}" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="action" value="save"/>
                    <input type="hidden" name="activetab" value="{{ fsc.getCurrentView().getViewName() }}"/>
                    <input type="hidden" name="code" value="{{ model.primaryColumnValue() }}"/>
                    <input type="hidden" name="multireqtoken" value="{{ fsc.multiRequestProtection.newToken() }}"/>

                    <ul class="nav nav-tabs" id="rutaTabs" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" id="general-tab" data-toggle="tab" href="#general" role="tab" aria-controls="general" aria-selected="true">
                                <i class="fas fa-info-circle"></i> {{ i18n.trans('general') }}
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="destinos-tab" data-toggle="tab" href="#destinos" role="tab" aria-controls="destinos" aria-selected="false">
                                <i class="fas fa-map-marker-alt"></i> {{ i18n.trans('destinations') }}
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="empleados-tab" data-toggle="tab" href="#empleados" role="tab" aria-controls="empleados" aria-selected="false">
                                <i class="fas fa-users"></i> {{ i18n.trans('employees') }}
                            </a>
                        </li>
                    </ul>

                    <div class="tab-content" id="rutaTabsContent">
                        {# Pestaña General #}
                        <div class="tab-pane fade show active" id="general" role="tabpanel" aria-labelledby="general-tab">
                            <div class="card">
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="nombre">{{ i18n.trans('name') }}</label>
                                                <input type="text" class="form-control" id="nombre" name="nombre"
                                                       value="{{ model.nombre }}" maxlength="100" required/>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="form-group">
                                                <label for="fecha_inicio">{{ i18n.trans('start-date') }}</label>
                                                <input type="date" class="form-control" id="fecha_inicio" name="fecha_inicio"
                                                       value="{{ model.fecha_inicio|date('Y-m-d') }}"/>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="form-group">
                                                <label for="fecha_fin">{{ i18n.trans('end-date') }}</label>
                                                <input type="date" class="form-control" id="fecha_fin" name="fecha_fin"
                                                       value="{{ model.fecha_fin|date('Y-m-d') }}"/>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <div class="custom-control custom-switch">
                                                    <input type="checkbox" class="custom-control-input" id="optimizada"
                                                           name="optimizada" value="1" {% if model.optimizada %}checked{% endif %}/>
                                                    <label class="custom-control-label" for="optimizada">
                                                        {{ i18n.trans('optimized') }}
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row mt-3">
                                        <div class="col-12">
                                            <div class="form-group">
                                                <label>{{ i18n.trans('created-at') }}:</label>
                                                <span class="text-muted">{{ model.created_at|date('d/m/Y H:i:s') }}</span>
                                            </div>
                                            <div class="form-group">
                                                <label>{{ i18n.trans('updated-at') }}:</label>
                                                <span class="text-muted">{{ model.updated_at|date('d/m/Y H:i:s') }}</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# Pestaña Destinos #}
                        <div class="tab-pane fade" id="destinos" role="tabpanel" aria-labelledby="destinos-tab">
                            {{ include('Tab/DestinoRuta.html.twig') }}
                        </div>

                        {# Pestaña Empleados - Contenido personalizado #}
                        <div class="tab-pane fade" id="empleados" role="tabpanel" aria-labelledby="empleados-tab">
                            <div class="container-fluid">
                                <div class="row">
                                    <div class="col-12">
                                        <div class="card">
                                            <div class="card-header">
                                                <h3 class="card-title">
                                                    <i class="fas fa-users"></i> {{ i18n.trans('employees') }}
                                                </h3>
                                            </div>
                                            <div class="card-body">
                                                {% include 'Tab/EmpleadosRuta.html.twig' %}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer">
                        <div class="row">
                            <div class="col">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> {{ i18n.trans('save') }}
                                </button>
                                <a href="{{ fsc.url() }}" class="btn btn-secondary">
                                    <i class="fas fa-undo"></i> {{ i18n.trans('cancel') }}
                                </a>
                            </div>
                            <div class="col-auto">
                                {% if model.exists() %}
                                    <div class="btn-group">
                                        <a href="{{ fsc.url() }}?action=delete&amp;code={{ model.primaryColumnValue() }}&amp;multireqtoken={{ fsc.multiRequestProtection.newToken() }}"
                                           class="btn btn-danger" onclick="return confirm('{{ i18n.trans('confirm-delete') }}')">
                                            <i class="fas fa-trash-alt"></i> {{ i18n.trans('delete') }}
                                        </a>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        $(document).ready(function() {
            // Activar pestañas
            $('#rutaTabs a').on('click', function (e) {
                e.preventDefault();
                $(this).tab('show');
            });

            // Guardar pestaña activa
            $('a[data-toggle="tab"]').on('shown.bs.tab', function (e) {
                localStorage.setItem('activeTab_ruta', $(e.target).attr('href'));
            });

            // Restaurar pestaña activa
            var activeTab = localStorage.getItem('activeTab_ruta');
            if (activeTab) {
                $('#rutaTabs a[href="' + activeTab + '"]').tab('show');
            }
        });
    </script>
{% endblock %}
