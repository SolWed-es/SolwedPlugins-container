<table class="table table-hover">
    <thead>
        <tr>
            <th>{{ i18n.trans('employee') }}</th>
            <th>{{ i18n.trans('assignment-date') }}</th>
            <th class="text-right">{{ i18n.trans('actions') }}</th>
        </tr>
    </thead>
    <tbody>
        {% for assignment in assignedRoutes %}
            <tr>
                <td>{{ assignment.getEmployee().getFullName() }}</td>
                <td>{{ assignment.fecha_asignacion }}</td>
                <td class="text-right">
                    <a href="#" class="btn btn-sm btn-danger unassign-ruta" data-id="{{ assignment.id }}">
                        <i class="fas fa-trash-alt"></i>
                        <span class="d-none d-sm-inline-block">&nbsp;{{ i18n.trans('unassign') }}</span>
                    </a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3" class="text-center">{{ i18n.trans('no-employees-assigned') }}</td>
            </tr>
        {% endfor %}
    </tbody>
</table>
