<?xml version="1.0" encoding="UTF-8"?>
<view>
    <columns>
        <column name="id" display="none" order="100">
            <widget type="number" fieldname="id" />
        </column>

        <!-- Campo idruta oculto pero presente -->
        <column name="idruta" display="none" order="105">
            <widget type="number" fieldname="idruta" />
        </column>

        <!-- Selector de destino -->
        <column name="destination" display="left" order="110">
            <widget type="select" fieldname="iddestino" required="true">
                <values source="destinos" fieldcode="iddestino" fieldtitle="nombre" />
            </widget>
        </column>

        <!-- Dirección del destino (solo lectura) -->
        <column name="address" display="left" order="120">
            <widget type="text" fieldname="direccion" readonly="true" />
        </column>

        <!-- Ciudad del destino (solo lectura) -->
        <column name="city" display="left" order="130">
            <widget type="text" fieldname="ciudad" readonly="true" />
        </column>

        <!-- Orden editable -->
        <column name="order" display="center" order="140">
            <widget type="number" fieldname="orden" min="1" max="999" />
        </column>
    </columns>

    <filters>
        <filter name="destination" type="select" fieldname="iddestino">
            <values source="destinos" fieldcode="iddestino" fieldtitle="nombre" />
        </filter>
    </filters>
</view>