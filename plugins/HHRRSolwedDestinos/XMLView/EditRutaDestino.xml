<?xml version="1.0" encoding="UTF-8"?>
<view>
    <columns>
        <group name="data" numcolumns="12">
            <column name="id" display="none" order="0">
                <widget type="number" fieldname="id" readonly="true" />
            </column>

            <!-- Oculto: idruta se hereda de la ruta -->
            <column name="route" order="100">
                <widget type="select" fieldname="idruta" required="true">
                    <values source="rutas" fieldcode="idruta" fieldtitle="nombre" />
                </widget>
            </column>

            <!-- Solo lectura: nombre del destino -->
            <column name="destination" order="110" numcolumns="4">
                <widget type="select" fieldname="iddestino" required="true">
                    <values source="destinos" fieldcode="iddestino" fieldtitle="nombre" />
                </widget>
            </column>

            <!-- Solo lectura: dirección -->
            <column name="address" order="120" numcolumns="4">
                <widget type="text" fieldname="direccion" readonly="true">
                    <values source="destinos" fieldcode="iddestino" fieldtitle="direccion" />
                </widget>
            </column>

            <!-- Solo lectura: ciudad -->
            <column name="city" order="130" numcolumns="2">
                <widget type="text" fieldname="ciudad" readonly="true">
                    <values source="destinos" fieldcode="iddestino" fieldtitle="ciudad" />
                </widget>
            </column>

            <!-- Solo editable: orden -->
            <column name="order" order="140" numcolumns="2">
                <widget type="number" fieldname="orden" min="1" max="999" />
            </column>
        </group>
    </columns>
</view>