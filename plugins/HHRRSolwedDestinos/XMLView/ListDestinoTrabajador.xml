<view>
    <columns>
        <column name="code" order="100">
            <widget type="text" fieldname="id" />
        </column>
        <column name="worker" order="110">
            <widget type="select" fieldname="idemployee">
                <values source="rrhh_employees" fieldcode="id" fieldtitle="nombre" />
            </widget>
        </column>
        <column name="destination" order="120">
            <widget type="select" fieldname="iddestino">
                <values source="destinos" fieldcode="iddestino" fieldtitle="nombre" />
            </widget>
        </column>
        <column name="date" order="130">
            <widget type="date" fieldname="fecha" />
        </column>
    </columns>
</view>