<view>
    <columns>
        <group name="data" numcolumns="12" title="data">
            <column name="code" order="0" display="none">
                <widget type="text" fieldname="id" readonly="true" />
            </column>
            <column name="worker" order="100" numcolumns="6">
                <widget type="select" fieldname="idemployee" required="true">
                    <values source="rrhh_employees" fieldcode="id" fieldtitle="nombre" />
                </widget>
            </column>
            <column name="destination" order="110" numcolumns="6">
                <widget type="select" fieldname="iddestino" required="true">
                    <values source="destinos" fieldcode="iddestino" fieldtitle="nombre" />
                </widget>
            </column>
            <column name="date" order="120" numcolumns="12">
                <widget type="date" fieldname="fecha" required="true" />
            </column>
        </group>
    </columns>
</view>