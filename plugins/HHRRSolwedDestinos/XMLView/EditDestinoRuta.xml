<view>
    <columns>
        <group name="data" numcolumns="12" title="data">
            <column name="code" order="0" display="none">
                <widget type="text" fieldname="id" readonly="true" />
            </column>
            <column name="route" order="100" numcolumns="12" title="Ruta" display="none">
                <widget type="select" fieldname="idruta" required="true">
                    <values source="rutas" fieldcode="idruta" fieldtitle="nombre" />
                </widget>
            </column>
            <column name="destination" order="110" numcolumns="6" title="Destino">
                <widget type="autocomplete" fieldname="iddestino" required="true">
                    <values source="destinos" fieldcode="iddestino" fieldtitle="nombre" />
                </widget>
            </column>
            <column name="order" order="120" numcolumns="6" title="Orden de visita">
                <widget type="number" fieldname="orden" required="true" min="1" max="999" />
            </column>
            <!-- ELIMINADO: Campo created_at que no existe en la tabla -->
        </group>
    </columns>
</view>