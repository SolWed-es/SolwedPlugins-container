<view>
    <columns>
        <column name="code" order="100" title="Código">
            <widget type="text" fieldname="idruta" />
        </column>
        <column name="name" order="110" title="Nombre">
            <widget type="text" fieldname="nombre" />
        </column>
        <column name="start-date" order="120" title="Fecha Inicio">
            <widget type="date" fieldname="fecha_inicio" />
        </column>
        <column name="end-date" order="130" title="Fecha Fin">
            <widget type="date" fieldname="fecha_fin" />
        </column>
        <column name="optimized" order="140" title="Optimizada" display="center">
            <widget type="checkbox" fieldname="optimizada" />
        </column>
        <column name="created" order="150" title="Creado">
            <widget type="datetime" fieldname="created_at" />
        </column>
        <column name="updated" order="160" title="Actualizado">
            <widget type="datetime" fieldname="updated_at" />
        </column>
    </columns>
    <row>
        <option name="action" value="edit" title="Editar" icon="fas fa-edit" />
        <option name="action" value="delete" title="Eliminar" icon="fas fa-trash-alt" />
    </row>
</view>