<view>
    <columns>
        <column name="employee-name" order="100">
            <widget type="text" fieldname="employee_name" readonly="true" />
        </column>
        <column name="shift-location" order="110">
            <widget type="text" fieldname="shift_location" readonly="true" />
        </column>
        <column name="shift-number" order="120">
            <widget type="number" fieldname="shift_number" readonly="true" />
        </column>
        <column name="assignment-date" order="140">
            <widget type="date" fieldname="assignment_date" readonly="true" />
        </column>
        <column name="start-date" order="150">
            <widget type="date" fieldname="start_date" readonly="true" />
        </column>
        <column name="end-date" order="160">
            <widget type="date" fieldname="end_date" readonly="true" />
        </column>
        <column name="active" order="170">
            <widget type="checkbox" fieldname="active" readonly="true" />
        </column>
    </columns>
</view>