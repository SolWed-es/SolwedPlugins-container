<table>
    <column>
        <name>id</name>
        <type>INTEGER</type>
        <null>NO</null>
        <autoincrement>true</autoincrement>
    </column>
    <column>
        <name>idruta</name>
        <type>INTEGER</type>
        <null>NO</null>
    </column>
    <column>
        <name>iddestino</name>
        <type>INTEGER</type>
        <null>NO</null>
    </column>
    <column>
        <name>orden</name>
        <type>INTEGER</type>
        <null>NO</null>


        <default>1</default>
    </column>

    <constraint>
        <name>ruta_destino_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ruta_destino_idruta_fkey</name>
        <type>FOREIGN KEY (idruta) REFERENCES rutas(idruta) ON DELETE CASCADE</type>
    </constraint>
    <constraint>
        <name>ruta_destino_iddestino_fkey</name>
        <type>FOREIGN KEY (iddestino) REFERENCES destinos(iddestino) ON DELETE CASCADE</type>
    </constraint>
    <constraint>
        <name>ruta_destino_unique</name>
        <type>UNIQUE (idruta, iddestino)</type>
    </constraint>
</table>