<?xml version="1.0" encoding="UTF-8"?>
<!--
    Document   : rrhh_employeeroutes.xml
    Author     : Jose Antonio Cuello Principal
    Description: Table structure for employee route assignments

    This file is part of HHRRSolwedDestinos plugin for FacturaScripts.
    Developed by Jose Antonio Cuello Principal based on the excellent work of the Human Resources
    plugin created by Carlos García Gómez and Jose Antonio Cuello Principal.
-->
<table>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idemployee</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>idruta</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>fecha_asignacion</name>
        <type>date</type>
        <null>NO</null>
        <default>CURRENT_DATE</default>
    </column>
    <column>
        <name>activo</name>
        <type>boolean</type>
        <null>NO</null>
        <default>true</default>
    </column>
    <column>
        <name>notas</name>
        <type>text</type>
    </column>
    <column>
        <name>created_at</name>
        <type>timestamp</type>
        <null>NO</null>
        <default>CURRENT_TIMESTAMP</default>
    </column>
    <column>
        <name>updated_at</name>
        <type>timestamp</type>
        <null>NO</null>
        <default>CURRENT_TIMESTAMP</default>
    </column>
    
    <!-- Primary Key -->
    <constraint>
        <name>rrhh_employeeroutes_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    
    <!-- Foreign Key to rrhh_employees -->
    <constraint>
        <name>rrhh_employeeroutes_idemployee_fkey</name>
        <type>FOREIGN KEY (idemployee) REFERENCES rrhh_employees(id) ON DELETE CASCADE</type>
    </constraint>
    
    <!-- Foreign Key to rutas -->
    <constraint>
        <name>rrhh_employeeroutes_idruta_fkey</name>
        <type>FOREIGN KEY (idruta) REFERENCES rutas(idruta) ON DELETE CASCADE</type>
    </constraint>
    
    <!-- Unique constraint to prevent duplicate assignments -->
    <constraint>
        <name>rrhh_employeeroutes_unique</name>
        <type>UNIQUE (idemployee, idruta, fecha_asignacion)</type>
    </constraint>
    
    <!-- Indexes for performance -->
    <index>
        <name>rrhh_employeeroutes_idemployee_idx</name>
        <type>INDEX (idemployee)</type>
    </index>
    <index>
        <name>rrhh_employeeroutes_idruta_idx</name>
        <type>INDEX (idruta)</type>
    </index>
    <index>
        <name>rrhh_employeeroutes_activo_idx</name>
        <type>INDEX (activo)</type>
    </index>
</table>