<view>
    <columns>
        <group name="data" numcolumns="12">
            <column name="code" order="0" display="none">
                <widget type="text" fieldname="id" readonly="true" />
            </column>
            <column name="location" order="100" numcolumns="6">
                <widget type="text" fieldname="location" required="true" />
            </column>
            <column name="shift-number" order="110" numcolumns="6">
                <widget type="number" fieldname="shift_number" required="true" min="1" />
            </column>
            <column name="entry-time" order="120" numcolumns="6">
                <widget type="time" fieldname="entry_time" required="true" />
            </column>
            <column name="exit-time" order="130" numcolumns="6">
                <widget type="time" fieldname="exit_time" required="true" />
            </column>
        </group>
        <group name="notes" numcolumns="12">
            <column name="notes" order="200">
                <widget type="textarea" fieldname="notes" />
            </column>
        </group>
    </columns>
</view>