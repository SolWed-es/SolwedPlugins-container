{# SolwedShadcn — Error de template #}
{% extends "Master/MicroTemplate.html.twig" %}

{% block body %}
    {{ parent() }}
    <div class="flex items-center justify-center min-h-[60vh] px-4">
        <div class="card-shadcn max-w-lg w-full">
            <div class="p-8 text-center">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-destructive/10 mb-4">
                    <i data-lucide="file-warning" class="w-8 h-8 text-destructive"></i>
                </div>
                <h1 class="text-xl font-heading font-semibold mb-2">{{ trans('template-error') }}</h1>
                <div class="mt-4 space-y-1 text-sm text-muted-foreground">
                    <p><span class="font-medium text-foreground">{{ trans('template') }}:</span> {{ template }}</p>
                    <p><span class="font-medium text-foreground">{{ trans('controller') }}:</span> {{ controllerName }}</p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
