{# SolwedShadcn — Wizard paso 3 (procesando) #}
{% extends "Master/MicroTemplate.html.twig" %}

{% block messages %}
    <div class="bg-primary pt-5 pb-5">
        <div class="container">
            <div class="row">
                <div class="col">
                    {{ parent() }}
                </div>
            </div>
        </div>
        <br/>
        <br/>
        <br/>
    </div>
{% endblock %}

{% block body %}
    <div class="container" style="margin-top: -100px;">
        <div class="card-shadcn mb-5">
            <div class="p-4">
                <h1 class="h3 font-heading font-semibold flex items-center gap-2">
                    <i data-lucide="wand-sparkles" class="w-6 h-6"></i> {{ trans('wizard') }}
                    <a href="{{ fsc.url() }}" class="btn btn-sm btn-outline-secondary ms-auto"
                       title="{{ trans('refresh') }}">
                        <i data-lucide="refresh-cw" class="w-4 h-4"></i>
                    </a>
                </h1>
                <p class="text-muted-foreground">{{ trans('wizard-p') }}</p>
                <hr class="border-border"/>
                <div class="text-center pt-5 pb-5 mt-5 mb-5">
                    <i data-lucide="loader-2" class="w-16 h-16 animate-spin text-muted-foreground mx-auto"></i>
                </div>
            </div>
        </div>
        <br/>
    </div>
{% endblock %}

{% block css %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('Dinamic/Assets/CSS/custom.css') }}"/>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('node_modules/pace-js/pace.min.js') }}"></script>
    <script src="{{ asset('Dinamic/Assets/JS/Custom.js') }}"></script>
{% endblock %}
