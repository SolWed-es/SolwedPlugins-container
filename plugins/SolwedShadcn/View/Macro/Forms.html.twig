{#
 * SolwedShadcn — Override de Forms.html.twig
 * Macros de formularios con estilo shadcn/Tailwind.
 * Las clases form-control y form-select se mantienen porque:
 *   1. Están mapeadas en bootstrap-compat.css a estilos shadcn
 *   2. Los widgets PHP Core las generan directamente
 #}

{# Macro simpleInput — input con label e icono opcionales #}
{% macro simpleInput(id, name, value, type = "text", label = NULL, icon = NULL, attributes = NULL) %}
    {% if label %}
        <label class="text-sm font-medium text-foreground mb-1" for="{{ name }}">{{ label }}</label>
    {% endif %}

    {% if icon %}
        <div class="input-group">
            <span class="input-group-text">
                <i class="{{ icon }} fa-fw" aria-hidden="true"></i>
            </span>
    {% endif %}

    <input type="{{ type }}" id="{{ id }}" name="{{ name }}" value="{{ value }}"
        {% if attributes.class is not defined %}
            class="form-control"
        {% endif %}
        {% for attribute, attrValue in attributes %}
            {{ attribute }}="{{ attrValue }}"
        {% endfor %} />

    {% if icon %}
        </div>
    {% endif %}
{% endmacro %}

{# Macro simpleSelect — select con label e icono opcionales #}
{% macro simpleSelect(id, name, value, allValues = {}, label = NULL, icon = NULL, attributes = NULL) %}
    {% if label %}
        <label class="text-sm font-medium text-foreground mb-1" for="{{ name }}">{{ label }}</label>
    {% endif %}

    {% if icon %}
        <div class="input-group">
            <span class="input-group-text">
                <i class="{{ icon }} fa-fw" aria-hidden="true"></i>
            </span>
    {% endif %}

    <select id="{{ id }}" name="{{ name }}"
        {% if attributes.class is not defined %}
            class="form-select"
        {% endif %}
        {% for attribute, attrValue in attributes %}
            {{ attribute }}="{{ attrValue }}"
        {% endfor %}>
        {% for key, option in allValues %}
            <option value="{{ key }}"{% if value == key %} selected="selected"{% endif %}>
                {{ option }}
            </option>
        {% endfor %}
    </select>

    {% if icon %}
        </div>
    {% endif %}
{% endmacro %}
