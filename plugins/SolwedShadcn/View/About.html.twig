{# SolwedShadcn — Acerca de #}
{% extends "Master/MenuBghTemplate.html.twig" %}

{% block bodyHeaderOptions %}
    <br/><br/><br/><br/><br/>
{% endblock %}

{% block body %}
    <div class="container" style="margin-top: -70px;">
        <div class="row">
            <div class="col-sm">
                {% for includeView in getIncludeViews('About', 'start') %}
                    {% include includeView['path'] %}
                {% endfor %}

                {% block software %}
                    <div class="card-shadcn mb-4">
                        <div class="p-4">
                            <h3 class="font-heading font-semibold flex items-center gap-2 mb-3">
                                <i data-lucide="code-2" class="w-6 h-6"></i> {{ trans('software') }}
                            </h3>
                            <hr class="border-border mb-3"/>
                            <div class="row align-items-center">
                                <div class="col-md">
                                    <h5 class="font-semibold mb-3">FacturaScripts</h5>
                                    <p class="mb-1">
                                        <strong>{{ trans('version') }}:</strong> {{ fsc.data.core_version }}
                                    </p>
                                    <p class="mb-1">
                                        <strong>{{ trans('license') }}:</strong> LGPL v3
                                    </p>
                                    <p class="mb-1">
                                        <strong>{{ trans('website') }}:</strong>
                                        <a href="https://facturascripts.com" target="_blank" rel="nofollow">facturascripts.com</a>
                                    </p>
                                    <p class="mb-0">
                                        <strong>{{ trans('installation') }}:</strong>
                                        {% if settings('default', 'telemetryinstall') %}
                                            <span class="badge bg-success">{{ trans('registered') }}</span>
                                        {% else %}
                                            <span class="badge bg-warning">{{ trans('not-registered') }}</span>
                                        {% endif %}
                                    </p>
                                </div>
                                <div class="col-md-auto">
                                    <img src="{{ asset('Core/Assets/Images/horizontal-logo.png') }}" alt="FacturaScripts"
                                         class="img-fluid max-h-20">
                                </div>
                            </div>
                        </div>
                    </div>
                {% endblock %}

                {% block limits %}
                    <div class="card-shadcn mb-4">
                        <div class="p-4">
                            <h3 class="font-heading font-semibold flex items-center gap-2 mb-3">
                                <i data-lucide="bar-chart-3" class="w-6 h-6"></i> {{ trans('limits') }}
                            </h3>
                            <hr class="border-border mb-3"/>
                            <div class="row">
                                <div class="col-lg-2 col-md-4 col-sm-6">
                                    <div class="text-center p-2">
                                        <i data-lucide="hard-drive" class="w-8 h-8 text-foreground mb-2 mx-auto"></i>
                                        <h6 class="font-semibold mb-1">{{ trans('app-storage') }}</h6>
                                        <p class="mb-0 text-sm">
                                            {% set storageUsed = fsc.data.storage_used is defined ? fsc.data.storage_used : 0 %}
                                            {% set storageLimit = fsc.data.storage_limit is defined ? fsc.data.storage_limit : 0 %}
                                            <strong>{{ bytes(storageUsed) }}</strong>
                                            / {% if storageLimit %}{{ bytes(storageLimit) }}{% else %}&infin;{% endif %}
                                        </p>
                                    </div>
                                </div>
                                <div class="col-lg-2 col-md-4 col-sm-6">
                                    <div class="text-center p-2">
                                        <i data-lucide="users" class="w-8 h-8 text-info mb-2 mx-auto"></i>
                                        <h6 class="font-semibold mb-1">{{ trans('users') }}</h6>
                                        <p class="mb-0 text-sm">
                                            {% set userCount = fsc.data.limits.users is defined ? fsc.data.limits.users : 0 %}
                                            {% set userLimit = config('user_limit') %}
                                            <strong>{{ userCount }}</strong>
                                            / {% if userLimit %}{{ userLimit }}{% else %}&infin;{% endif %}
                                        </p>
                                    </div>
                                </div>
                                <div class="col-lg-2 col-md-4 col-sm-6">
                                    <div class="text-center p-2">
                                        <i data-lucide="box" class="w-8 h-8 text-success mb-2 mx-auto"></i>
                                        <h6 class="font-semibold mb-1">{{ trans('products') }}</h6>
                                        <p class="mb-0 text-sm">
                                            {% set productCount = fsc.data.limits.products is defined ? fsc.data.limits.products : 0 %}
                                            {% set productLimit = config('product_limit') %}
                                            <strong>{{ productCount }}</strong>
                                            / {% if productLimit %}{{ productLimit }}{% else %}&infin;{% endif %}
                                        </p>
                                    </div>
                                </div>
                                <div class="col-lg-2 col-md-4 col-sm-6">
                                    <div class="text-center p-2">
                                        <i data-lucide="user-check" class="w-8 h-8 text-info mb-2 mx-auto"></i>
                                        <h6 class="font-semibold mb-1">{{ trans('customers') }}</h6>
                                        <p class="mb-0 text-sm">
                                            {% set customerCount = fsc.data.limits.customers is defined ? fsc.data.limits.customers : 0 %}
                                            {% set customerLimit = config('customer_limit') %}
                                            <strong>{{ customerCount }}</strong>
                                            / {% if customerLimit %}{{ customerLimit }}{% else %}&infin;{% endif %}
                                        </p>
                                    </div>
                                </div>
                                <div class="col-lg-2 col-md-4 col-sm-6">
                                    <div class="text-center p-2">
                                        <i data-lucide="file-text" class="w-8 h-8 text-warning mb-2 mx-auto"></i>
                                        <h6 class="font-semibold mb-1">{{ trans('invoices') }}</h6>
                                        <p class="mb-0 text-sm">
                                            {% set invoiceCount = fsc.data.limits.invoices is defined ? fsc.data.limits.invoices : 0 %}
                                            {% set invoiceLimit = config('invoice_limit') %}
                                            <strong>{{ invoiceCount }}</strong>
                                            / {% if invoiceLimit %}{{ invoiceLimit }}{% else %}&infin;{% endif %}
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endblock %}

                {% block storage %}
                    <div class="card-shadcn mb-4">
                        <div class="p-4">
                            <h3 class="font-heading font-semibold flex items-center gap-2 mb-3">
                                <i data-lucide="hard-drive" class="w-6 h-6"></i> {{ trans('app-storage') }}
                            </h3>
                            <hr class="border-border mb-3"/>
                            <div class="row">
                                {% for dataStorare in fsc.data.storage_details %}
                                    <div class="col-lg-2 col-md-4 col-sm-6">
                                        <div class="text-center p-2">
                                            {% if dataStorare.name == 'files' %}
                                                <i data-lucide="file" class="w-8 h-8 text-muted-foreground mb-2 mx-auto"></i>
                                            {% else %}
                                                <i data-lucide="folder" class="w-8 h-8 text-muted-foreground mb-2 mx-auto"></i>
                                            {% endif %}
                                            <h6 class="font-semibold mb-1">{{ dataStorare.name }}</h6>
                                            <p class="mb-0 text-sm"><strong>{{ dataStorare.human_size }}</strong></p>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endblock %}

                {% block plugins %}
                    <div class="card-shadcn mb-4">
                        <div class="p-4">
                            <h3 class="font-heading font-semibold flex items-center gap-2">
                                <i data-lucide="plug" class="w-6 h-6"></i> {{ trans('plugins') }}
                                {% if fsc.data.plugins | length > 0 %}
                                    <span class="badge bg-secondary">{{ fsc.data.plugins | length }}</span>
                                {% endif %}
                            </h3>
                        </div>
                        {% if fsc.data.plugins | length > 0 %}
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                    <tr>
                                        <th scope="col">{{ trans('name') }}</th>
                                        <th scope="col">{{ trans('min-fs-version') }}</th>
                                        <th scope="col">{{ trans('plugins-required') }}</th>
                                        <th scope="col">{{ trans('min-php-version') }}</th>
                                        <th scope="col">{{ trans('php-extensions-required') }}</th>
                                        <th class="text-center" scope="col">{{ trans('enabled') }}</th>
                                        <th class="text-end" scope="col">{{ trans('priority') }}</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    {% for plugin in fsc.data.plugins %}
                                        <tr class="{{ plugin.enabled ? 'table-success' : 'table-secondary' }}">
                                            <td>
                                                <strong>{{ plugin.name }}</strong>
                                                <small class="text-muted-foreground">v{{ plugin.version }}</small>
                                            </td>
                                            <td>{{ plugin.min_version }}</td>
                                            <td>{{ plugin.require | join(', ') }}</td>
                                            <td>{{ plugin.min_php }}</td>
                                            <td>{{ plugin.require_php | join(', ') }}</td>
                                            <td class="text-center">
                                                {% if plugin.enabled %}
                                                    <span class="badge bg-success">{{ trans('yes') }}</span>
                                                {% else %}
                                                    <span class="badge bg-secondary">{{ trans('no') }}</span>
                                                {% endif %}
                                            </td>
                                            <td class="text-end">{{ plugin.order }}</td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% else %}
                            <div class="p-4 text-center text-muted-foreground">
                                <i data-lucide="puzzle" class="w-10 h-10 mb-3 mx-auto"></i>
                                <p class="mb-0">{{ trans('no-plugins-installed') }}</p>
                            </div>
                        {% endif %}
                    </div>
                {% endblock %}

                {% block server %}
                    <div class="card-shadcn mb-4">
                        <div class="p-4">
                            <h3 class="font-heading font-semibold flex items-center gap-2 mb-3">
                                <i data-lucide="server" class="w-6 h-6"></i> {{ trans('server') }}
                            </h3>
                            <hr class="border-border mb-3"/>
                            <div class="row">
                                <div class="col-lg-6">
                                    <p class="mb-1">
                                        <strong>PHP:</strong> {{ fsc.data.php_version }}
                                    </p>
                                    <p class="mb-1">
                                        <strong>{{ trans('php-extensions') }}:</strong>
                                        <small class="text-muted-foreground">{{ fsc.data.extensions | join(', ') }}</small>
                                    </p>
                                </div>
                                <div class="col-lg-6">
                                    <p class="mb-1">
                                        <strong>{{ trans('database') }}:</strong>
                                        {{ fsc.data.database_type }} {{ fsc.data.database_version }}
                                    </p>
                                    <p class="mb-1">
                                        <strong>{{ trans('server-software') }}:</strong>
                                        {{ fsc.data.server_software }}
                                    </p>
                                    <p class="mb-1">
                                        <strong>{{ trans('server-accepts-filesize') }}:</strong>
                                        {{ bytes(fsc.data.max_filesize) }}
                                    </p>
                                    <p class="mb-0">
                                        <strong>{{ trans('operating-system') }}:</strong>
                                        {{ fsc.data.os_info }}
                                    </p>
                                    <p class="mb-0">
                                        <strong>{{ trans('date') }}:</strong>
                                        {{ fsc.data.server_date }}
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endblock %}

                {% for includeView in getIncludeViews('About', 'end') %}
                    {% include includeView['path'] %}
                {% endfor %}
            </div>
        </div>
    </div>
{% endblock %}
