{#
/**
 * SolwedShadcn — Vista previa de archivos (PreviewFiles)
 */
#}
{% set firstView = fsc.views | first %}
{% set doc = firstView.model %}
{% set currentView = fsc.getCurrentView() %}

<div class="container-fluid">
    {# -- New form -- #}
    <div class="row">
        <div class="col">
            <form id="{{ 'form' ~ currentView.getViewName() ~ '0' }}" action="{{ doc.url() }}" method="post" enctype="multipart/form-data" onsubmit="animateSpinner('add')">
                {{ formToken() }}
                <input type="hidden" name="activetab" value="{{ currentView.getViewName() }}" />
                <input type="hidden" name="action" value="add-file" />
                <div class="card-shadcn border-success mb-2">
                    <div class="p-2">
                        <button class="btn btn-sm btn-outline-success" type="button" data-bs-toggle="collapse" data-bs-target="#NewFileCollapse" aria-expanded="false">
                            <i data-lucide="plus-square" class="w-4 h-4 me-1"></i>
                            {{ trans('add') }}
                        </button>
                        &nbsp;
                        {{ currentView.title }}
                    </div>
                    <div class="collapse" id="NewFileCollapse">
                        <div class="border-t border-border p-3">
                            {{ _self.inputTextArea('') }}
                            <div class="row align-items-end">
                                <div class="col">
                                    <input type="file" name="new-files[]" class="form-control" required multiple/>
                                    <p class="text-sm text-muted-foreground mb-0">{{ trans('help-server-accepts-filesize', {'%size%': currentView.model.getMaxFileUpload()}) }}</p>
                                </div>
                                <div class="col text-end">
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i data-lucide="save" class="w-3.5 h-3.5 me-1"></i> {{ trans('save') }}
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
    {# -- Attached files -- #}
    <div class="row">
        <div class="col">
            {% for counter, docfile in currentView.cursor %}
                {% set formName = currentView.getViewName() ~ (counter + 1) %}
                {% set file = docfile.getFile() %}
                {% set urlDownload = file.url('download') %}
                <form id="{{ 'form' ~ formName }}" action="{{ doc.url() }}" method="post" enctype="multipart/form-data" onsubmit="animateSpinner('add')">
                    {{ formToken() }}
                    <input type="hidden" name="activetab" value="{{ currentView.getViewName() }}" />
                    <input type="hidden" name="id" value="{{ docfile.id }}" />
                    <input type="hidden" name="action" value="edit-file"/>
                    <div class="card-shadcn mb-3">
                        <div class="p-3">
                            <div class="row">
                                <div class="col-md-9">
                                    <h5 class="font-semibold mb-3 flex items-center gap-2">
                                        <i data-lucide="image" class="w-5 h-5"></i> {{ file.filename }}
                                    </h5>
                                    {{ _self.inputTextArea(docfile.observations) }}
                                    <div class="row">
                                        <div class="col">
                                            {{ _self.buttonDelete(formName) }}
                                        </div>
                                        <div class="col text-center">
                                            <small class="text-muted-foreground">
                                                <i data-lucide="user" class="w-3 h-3 inline"></i> {{ docfile.nick }} &nbsp;
                                                <i data-lucide="calendar" class="w-3 h-3 inline"></i> {{ docfile.creationdate }}
                                            </small>
                                        </div>
                                        <div class="col text-end">
                                            <a class="btn btn-sm btn-outline-info" target="_blank" href="{{ asset(urlDownload) }}">
                                                <i data-lucide="cloud-download" class="w-3.5 h-3.5 me-1"></i>
                                                <span class="d-none d-sm-inline-block">{{ trans('download') }}</span>
                                            </a>
                                            <button class="btn btn-sm btn-primary" type="submit" name="action" value="edit-file">
                                                <i data-lucide="save" class="w-3.5 h-3.5 me-1"></i>
                                                <span class="d-none d-sm-inline-block">{{ trans('save') }}</span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3 text-center">
                                    {{ _self.previewFile(urlDownload, file.filename, file.getExtension()) }}
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            {% endfor %}
        </div>
    </div>
</div>

{% macro inputTextArea(text) %}
    <div class="mb-3">
        <textarea name="observations" class="form-control" rows="4" placeholder="{{ trans('observations') }}">{{ text }}</textarea>
    </div>
{% endmacro %}

{% macro previewFile(url, filename, extFile) %}
    <style>
        .preview-fit { width: inherit; height: 200px; max-width: 100%; max-height: 100%; object-fit: contain; }
    </style>
    {% if extFile in ['gif','jpg', 'jpeg','png', 'svg', 'webp'] %}
        <img src="{{ asset(url) }}" class="preview-fit rounded border border-border" alt="{{ filename }}">
    {% elseif extFile in ['mp4', 'ogg', 'webm'] %}
        <div class="ratio ratio-16x9">
            <video class="preview-fit" controls><source src="{{ asset(url) }}" type="video/{{ extFile }}" /></video>
        </div>
    {% elseif extFile == 'pdf' %}
        <embed class="preview-fit" src="{{ asset(url) }}" type="application/pdf">
    {% else %}
        <p class="text-sm text-muted-foreground">{{ trans('preview-file-type-not-soported') }}</p>
    {% endif %}
{% endmacro %}

{% macro buttonDelete(formName) %}
    {% set label = trans('delete-file') %}
    {% set text = trans('are-you-sure') %}
    {% set cancel = trans('cancel') %}
    {% set confirm = trans('confirm') %}
    <button type="button" class="btn btn-sm btn-danger"
            onclick="confirmAction('{{ formName }}','delete-file','{{ label }}','{{ text }}','{{ cancel }}','{{ confirm }}');">
        <i data-lucide="trash-2" class="w-3.5 h-3.5 me-1"></i>
        <span class="d-none d-sm-inline-block">{{ trans('delete') }}</span>
    </button>
{% endmacro %}
