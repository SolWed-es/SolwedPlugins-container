{# SolwedShadcn — Header top bar (inspirado en solwed-app Header.tsx) #}
<header class="solwed-header d-print-none">
    <div class="flex items-center gap-3">
        {# Botón hamburguesa en móvil #}
        <button type="button" class="inline-flex items-center justify-center rounded-md h-9 w-9 hover:bg-muted transition-colors lg:hidden"
                onclick="toggleSidebar()" title="Menu">
            <i data-lucide="menu" class="w-5 h-5"></i>
        </button>

        {# Nombre de empresa #}
        <a href="{{ asset(fsc.user.homepage) }}" class="text-foreground font-semibold text-sm hover:text-foreground/80 transition-colors hidden md:inline-block"
           title="{{ trans('homepage') }}">
            {{ fsc.empresa.nombrecorto | raw }}
        </a>
    </div>

    <div class="flex items-center gap-1">
        {% for includeView in getIncludeViews('MenuTemplate', 'MenuIconBefore') %}
            {% include includeView['path'] %}
        {% endfor %}

        {# Búsqueda #}
        <a href="MegaSearch" id="menuIconSearch"
           class="inline-flex items-center justify-center rounded-md h-9 w-9 hover:bg-muted transition-colors{{ template == 'MegaSearch.html.twig' ? ' bg-muted' : '' }}"
           title="{{ trans('search') }}">
            <i data-lucide="search" class="w-4 h-4"></i>
        </a>

        {# Dashboard #}
        <a href="Dashboard" id="menuIconDashboard"
           class="inline-flex items-center justify-center rounded-md h-9 w-9 hover:bg-muted transition-colors{{ template == 'Dashboard.html.twig' ? ' bg-muted' : '' }}"
           title="{{ trans('dashboard') }}">
            <i data-lucide="layout-dashboard" class="w-4 h-4"></i>
        </a>

        {# Ayuda #}
        <a href="https://facturascripts.com/ayuda?controller={{ controllerName }}" id="menuIconHelp"
           class="inline-flex items-center justify-center rounded-md h-9 w-9 hover:bg-muted transition-colors hidden sm:inline-flex"
           rel="nofollow" target="_blank" title="{{ trans('help') }}">
            <i data-lucide="circle-help" class="w-4 h-4"></i>
        </a>

        {# Separador #}
        <div class="w-px h-6 bg-border mx-1 hidden sm:block"></div>

        {# Menú usuario #}
        <div class="dropdown">
            <button type="button"
                    class="inline-flex items-center gap-2 rounded-md h-9 px-3 hover:bg-muted transition-colors text-sm"
                    data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" id="menuIconUser"
                    title="{{ trans('user') }}">
                <i data-lucide="circle-user" class="w-4 h-4"></i>
                <span class="hidden sm:inline">{{ fsc.user.nick }}</span>
                <i data-lucide="chevron-down" class="w-3 h-3 opacity-50"></i>
            </button>
            <div class="dropdown-menu dropdown-menu-end" aria-labelledby="menuIconUser">
                <a class="dropdown-item" href="{{ fsc.user.url() }}">
                    <i data-lucide="user" class="w-4 h-4 me-2"></i> {{ fsc.user.nick }}
                </a>
                <a class="dropdown-item" href="SendMail">
                    <i data-lucide="mail" class="w-4 h-4 me-2"></i> {{ trans('send-mail') }}
                </a>
                {% for includeView in getIncludeViews('MenuTemplate', 'MenuIconUser') %}
                    {% include includeView['path'] %}
                {% endfor %}
                <div class="dropdown-divider"></div>
                <a class="dropdown-item text-destructive" href="{{ asset('login') }}?action=logout&multireqtoken={{ formToken(false) }}">
                    <i data-lucide="log-out" class="w-4 h-4 me-2"></i> {{ trans('logout') }}
                </a>
            </div>
        </div>

        {% for includeView in getIncludeViews('MenuTemplate', 'MenuIconAfter') %}
            {% include includeView['path'] %}
        {% endfor %}
    </div>
</header>
